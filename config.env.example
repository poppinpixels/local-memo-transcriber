# Runtime config for the local memo transcription pipeline.
# install.sh copies this to ~/LocalMemoTranscriber/config.env on first run.

MODEL_ID=syvai/hviske-v3-conversation
WATCH_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/LocalMemoTranscriber/inbox"
TRANSCRIPTS_DIR=$HOME/LocalMemoTranscriber/transcripts
DONE_DIR=$HOME/LocalMemoTranscriber/done
FAILED_DIR=$HOME/LocalMemoTranscriber/failed
LOG_DIR=$HOME/LocalMemoTranscriber/logs
TMP_DIR=$HOME/LocalMemoTranscriber/tmp
VENV_DIR=$HOME/LocalMemoTranscriber/venv
POLL_INTERVAL_SECONDS=1800
STABILITY_WAIT_SECONDS=30
LANGUAGE=da
OUTPUT_FORMATS=txt,json,srt
NORMALIZED_SAMPLE_RATE=16000
NORMALIZED_CHANNELS=1
CHUNK_LENGTH_SECONDS=30
STRIDE_LENGTH_SECONDS=10
MAX_NEW_TOKENS=445
DEVICE_PREFERENCE=auto
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
PYTHON_BIN=
SILENCE_THRESHOLD_DB=-35dB
MIN_SILENCE_DURATION=0.3

# Runtime config for the local memo transcription pipeline.
# install.sh copies this to ~/LocalMemoTranscriber/config.env on first run.
# Lines starting with # are ignored. All paths support $HOME expansion.

# ── Model ────────────────────────────────────────────────────────────
# Any Hugging Face model compatible with AutoModelForSpeechSeq2Seq.
# Examples:
#   openai/whisper-large-v3          (multilingual)
#   openai/whisper-large-v3-turbo    (multilingual, faster)
#   syvai/hviske-v3-conversation     (Danish conversational)
MODEL_ID=openai/whisper-large-v3

# ── Language ─────────────────────────────────────────────────────────
# ISO 639-1 code passed to the model's generate() call.
# Leave empty or set to "auto" to let the model detect the language.
# Examples: en, da, de, fr, es, nl, ja, zh
LANGUAGE=

# ── Directories ──────────────────────────────────────────────────────
# Where the watcher looks for new audio files. Default points to an
# iCloud Drive folder so you can share Voice Memos from iPhone via Files.
WATCH_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/LocalMemoTranscriber/inbox"
TRANSCRIPTS_DIR=$HOME/LocalMemoTranscriber/transcripts
DONE_DIR=$HOME/LocalMemoTranscriber/done
FAILED_DIR=$HOME/LocalMemoTranscriber/failed
LOG_DIR=$HOME/LocalMemoTranscriber/logs
TMP_DIR=$HOME/LocalMemoTranscriber/tmp
VENV_DIR=$HOME/LocalMemoTranscriber/venv

# ── Watcher ──────────────────────────────────────────────────────────
# How often the watcher polls the inbox (seconds). Default: 1800 (30 min).
POLL_INTERVAL_SECONDS=1800

# How long to wait for a file to stop changing before processing it.
# Helps with iCloud sync delays and partially downloaded files.
STABILITY_WAIT_SECONDS=30

# ── Audio normalization ──────────────────────────────────────────────
# ffmpeg converts input audio to mono PCM WAV at this sample rate before
# passing it to the model. 16000 Hz is standard for Whisper models.
NORMALIZED_SAMPLE_RATE=16000
NORMALIZED_CHANNELS=1

# ── Chunking ─────────────────────────────────────────────────────────
# Audio longer than CHUNK_LENGTH_SECONDS is split into chunks.
# The pipeline tries to split at silence points within the last
# STRIDE_LENGTH_SECONDS of each chunk for natural boundaries.
CHUNK_LENGTH_SECONDS=30
STRIDE_LENGTH_SECONDS=10

# ── Silence detection ────────────────────────────────────────────────
# Used by ffmpeg silencedetect to find natural split points.
# SILENCE_THRESHOLD_DB: volume below which audio counts as silence.
# MIN_SILENCE_DURATION: minimum silence length (seconds) to register.
SILENCE_THRESHOLD_DB=-35dB
MIN_SILENCE_DURATION=0.3

# ── Generation ───────────────────────────────────────────────────────
# Maximum tokens the model can generate per chunk. The pipeline
# automatically caps this at the model's max_target_positions.
MAX_NEW_TOKENS=445

# ── Output ───────────────────────────────────────────────────────────
# Comma-separated list of output formats: txt, json, srt
OUTPUT_FORMATS=txt,json,srt

# ── Device ───────────────────────────────────────────────────────────
# "auto" tries Apple GPU (MPS) first, falls back to CPU if output is
# unusable. Set to "cpu" to skip MPS entirely, or "mps" to force GPU.
DEVICE_PREFERENCE=auto

# ── External tools ───────────────────────────────────────────────────
# Paths to ffmpeg/ffprobe. Usually fine to leave as-is if installed
# via Homebrew (brew install ffmpeg).
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Override the Python binary used by the watcher (leave empty to use
# the venv python). Only needed if you have multiple Python installs.
PYTHON_BIN=
